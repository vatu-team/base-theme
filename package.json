{
    "name": "base-theme",
    "version": "1.0.0",
    "description": "NPM configuration for Base Theme development.",
    "author": "Vatu <info@vatu.dev>",
    "license": "MIT",
    "engines": {
        "npm": "^10.1.0",
        "node": "^20.9.0"
    },
    "scripts": {
        "build": "run-p 'build:theme'",
        "watch": "run-p 'watch:theme'",
        "build:theme": "wp-scripts build --config ./webpack.config.js",
        "watch:theme": "wp-scripts start --config ./webpack.config.js",
        "wp-env": "wp-env"
    },
    "devDependencies": {
        "@wordpress/env": "^10.20.0",
        "@wordpress/scripts": "^30.14.0",
        "copy-webpack-plugin": "^13.0.0",
        "glob": "^11.0.1",
        "npm-run-all": "^4.1.5",
        "path": "^0.12.7",
        "rtlcss-webpack-plugin": "^4.0.7",
        "webpack-remove-empty-scripts": "^1.0.4"
    }
}

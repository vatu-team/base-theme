{
    "$schema": "https://schemas.wp.org/trunk/theme.json",
    "version": 3,
    "title": "Base Theme",
    "description": "Site styles for base theme..",
    "patterns": [],
    "settings": {
        "appearanceTools": false,
        "useRootPaddingAwareAlignments": true,
        "blocks": {
            "core/paragraph": {
                "typography": {
                    "fontFamilies": [],
                    "fontSizes": [
                        {
                            "slug": "small",
                            "name": "Small",
                            "size": "var( --wp--custom--font-size--body--small )"
                        },
                        {
                            "slug": "medium",
                            "name": "Medium",
                            "size": "var( --wp--custom--font-size--body--medium )"
                        },
                        {
                            "name": "Large",
                            "slug": "large",
                            "size": "var( --wp--custom--font-size--body--large )"
                        }
                    ]
                }
            },
            "core/heading": {
                "typography": {
                  "fontSizes": [
                    {
                      "name": "xxLarge",
                      "slug": "xxlarge",
                      "size": "var( --wp--custom--font-size--heading--xxlarge )"
                    },
                    {
                      "name": "xLarge",
                      "slug": "xlarge",
                      "size": "var( --wp--custom--font-size--heading--xlarge )"
                    },
                    {
                      "name": "Large",
                      "slug": "large",
                      "size": "var( --wp--custom--font-size--heading--large )"
                    },
                    {
                      "name": "Medium",
                      "slug": "medium",
                      "size": "var( --wp--custom--font-size--heading--medium )"
                    },
                    {
                      "name": "Small",
                      "slug": "small",
                      "size": "var( --wp--custom--font-size--heading--small )"
                    },
                    {
                      "name": "xSmall",
                      "slug": "xsmall",
                      "size": "var( --wp--custom--font-size--heading--xsmall )"
                    }
                  ],
                  "fontFamilies": []
                }
            },
            "core/list": {
                "typography": {
                    "fontFamilies": []
                }
            },
            "core/list-item": {
                "typography": {
                    "fontFamilies": []
                }
            },
            "core/quote": {
                "typography": {
                    "fontFamilies": []
                }
            },
            "core/table": {
                "typography": {
                    "fontFamilies": []
                }
            },
            "core/pullquote": {
                "border": {
                    "color": false,
                    "radius": false
                },
                "typography": {
                    "fontFamilies": []
                }
            },
            "core/details": {
                "typography": {
                    "fontFamilies": []
                }
            },
            "core/code": {
                "typography": {
                    "fontFamilies": []
                }
            },
            "core/preformatted": {
                "typography": {
                    "fontFamilies": []
                }
            },
            "core/verse": {
                "typography": {
                    "fontFamilies": []
                }
            }
        },
        "border": {
            "color": false,
            "radius": false,
            "style": false,
            "width": false
        },
        "color": {
            "text": false,
            "background": false,
            "link": false,
            "custom": false,
            "customDuotone": false,
            "customGradient": false,
            "defaultDuotone": false,
            "defaultGradients": false,
            "defaultPalette": false
        },
        "layout": {
            "contentSize": "clamp(288px, 80vw, 750px)",
            "wideSize": "clamp(288px, 90vw, 1200px)"
        },
        "position": {
            "sticky": true
        },
        "spacing": {
            "blockGap": false,
            "customSpacingSize": false,
            "margin": false,
            "padding": false
        },
        "shadow": {
            "defaultPresets": false
        },
        "typography": {
            "customFontSize": false,
            "defaultFontSizes": false,
            "dropCap": false,
            "fontFamilies": [
                {
                    "slug": "default",
                    "name": "Default",
                    "fontFamily": "-apple-system, blinkmacsystemfont, \"Segoe UI\", roboto, helvetica, arial, sans-serif"
                }
            ],
            "fontStyle": false,
            "fontWeight": false,
            "letterSpacing": false,
            "lineHeight": false,
            "textColumns": false,
            "textDecoration": false,
            "textTransform": false,
            "writingMode": false
        },
        "custom": {
            "font-size": {
                "body": {
                    "small": "clamp(0.8889rem, 0.7981rem + 0.4541vw, 1.15rem)",
                    "medium": "clamp(1rem, 0.8478rem + 0.7609vw, 1.4375rem)",
                    "large": "clamp(1.125rem, 0.8913rem + 1.1685vw, 1.7969rem)",
                    "xlarge": "clamp(1.2656rem, 0.9246rem + 1.7052vw, 2.2461rem)"
                },
                "heading": {
                    "xsmall": "clamp(1rem, 0.8478rem + 0.7609vw, 1.4375rem)",
                    "small": "clamp(1.125rem, 0.8913rem + 1.1685vw, 1.7969rem)",
                    "medium": "clamp(1.2656rem, 0.9246rem + 1.7052vw, 2.2461rem)",
                    "large": "clamp(1.4238rem, 0.9425rem + 2.4066vw, 2.8076rem)",
                    "xlarge": "clamp(1.6018rem, 0.9383rem + 3.3178vw, 3.5095rem)",
                    "xxlarge": "clamp(1.802rem, 0.9029rem + 4.4954vw, 4.3869rem)"
                }
            },
            "font-weight": {
                "thin": "100",
                "light-extra": "200",
                "light": "300",
                "normal": "400",
                "medium": "500",
                "bold-semi": "600",
                "bold": "700",
                "bold-extra": "800",
                "black": "900"
            }
        }
    },
    "styles": {
        "elements": {
            "heading": {
              "typography": {
                "lineHeight": "1.1"
              }
            },
            "h1": {
              "typography": {
                "fontSize": "var( --wp--custom--font-size--heading--xlarge )"
              }
            },
            "h2": {
              "typography": {
                "fontSize": "var( --wp--custom--font-size--heading--large )"
              }
            },
            "h3": {
              "typography": {
                "fontSize": "var( --wp--custom--font-size--heading--medium )"
              }
            },
            "h4": {
              "typography": {
                "fontSize": "var( --wp--custom--font-size--heading--small )"
              }
            },
            "h5": {
              "typography": {
                "fontSize": "var( --wp--custom--font-size--heading--xsmall )"
              }
            },
            "h6": {
              "typography": {
                "fontSize": "var( --wp--custom--font-size--heading--xsmall )"
              }
            },
            "link": {
              "color": {
                "text": "inherit"
              }
            }
          },
        "typography": {
            "fontFamily" : "var( --wp--preset--font-family--default )",
            "fontSize": "var( --wp--custom--font-size--body--medium )",
            "fontWeight" : "var( --wp--custom--font-weight--normal )",
            "lineHeight": "1.5",
            "letterSpacing": "0"
        }
    },
    "templateParts": [
        {
            "area": "header",
            "name": "site-header",
            "title": "Site Header"
        },
        {
            "area": "footer",
            "name": "site-footer",
            "title": "Site Footer"
        }
    ],
    "customTemplates": []
}
